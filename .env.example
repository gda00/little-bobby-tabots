# Bobby TaBot — Local Environment
# Copy this file to .env and fill in your token.
# .env is gitignored and will never be committed.

DISCORD_TOKEN=your_bot_token_here

# Optional: default YouTube clip and probability for /preplay
# PREPLAY_URL=https://www.youtube.com/watch?v=your_video_id
# PREPLAY_CHANCE_PERCENT=75

# Optional: control log verbosity
# RUST_LOG=bobby_tabot=debug,songbird=info,serenity=warn
